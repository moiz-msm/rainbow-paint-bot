# Copy this file to ".env" (or set these in your host's dashboard).
# NEVER share these values publicly.

# --- Meta WhatsApp Business API (from business.facebook.com / WhatsApp > API Setup) ---
WHATSAPP_TOKEN=your_meta_permanent_access_token
PHONE_NUMBER_ID=your_phone_number_id
VERIFY_TOKEN=rainbowpaint_verify

# --- LLM (OpenRouter) ---
# Use your existing free key. Model below is free via OpenRouter.
OPENROUTER_API_KEY=your_openrouter_key
BOT_MODEL=meta-llama/llama-3.3-70b-instruct:free

# --- Host ---
PORT=5000
PUBLIC_BASE_URL=https://your-render-app.onrender.com

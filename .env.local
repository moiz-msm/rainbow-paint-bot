# ─── LOCAL DESKTOP RUN (Ollama on this PC) ───────────────────────────────
# Bot runs on YOUR desktop, model runs LOCALLY (free, no throttling, no cloud bill).
# Cloud models are kept as fallbacks (only used if Ollama is down).

# --- Meta WhatsApp Business API ---
WHATSAPP_TOKEN=[REDACTED]
PHONE_NUMBER_ID=112529483880083
VERIFY_TOKEN=rainbowpaint_verify

# --- LLM: LOCAL Ollama is PRIMARY (free, on-PC) ---
# qwen2.5:0.5b is tiny (~400MB) and fits your 8GB PC with ~1GB free RAM.
# Chain in code: ollama:qwen2.5:0.5b -> openrouter free -> gemini -> openrouter(mistral-nemo paid)
BOT_MODEL=ollama:qwen2.5:0.5b
OPENROUTER_API_KEY=[REDACTED]
GEMINI_API_KEY=

# --- Host / tunnel (set by run_local_bot.sh after cloudflared starts) ---
PORT=5000
PUBLIC_BASE_URL=
